  "version": "1.0.0",
  "main": "index.js",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run prisma:generate && concurrently -n backend,frontend -c green,blue \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "nodemon backend/index.js",
    "start:frontend": "npm run dev -w frontend",
    "prisma:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "postinstall": "npm run prisma:generate"
  },
